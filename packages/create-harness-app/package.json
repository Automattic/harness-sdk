{
  "name": "create-harness-app",
  "version": "0.1.1",
  "description": "Create a Harness App SDK demo app.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/f/harness-sdk.git",
    "directory": "packages/create-harness-app"
  },
  "bugs": {
    "url": "https://github.com/f/harness-sdk/issues"
  },
