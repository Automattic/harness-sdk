{
  "name": "harness-app-sdk",
  "version": "0.1.0",
  "description": "Extend Harness with local AI accounts. No API keys.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/f/harness-sdk.git",
    "directory": "packages/harness-app-sdk"
  },
  "bugs": {
    "url": "https://github.com/f/harness-sdk/issues"
  },
  "homepage": "https://github.com/f/harness-sdk/tree/main/packages/harness-app-sdk#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
