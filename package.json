{
  "name": "harness-sdk-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Extend Harness with local AI accounts. No API keys.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/f/harness-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/f/harness-sdk/issues"
  },
  "homepage": "https://github.com/f/harness-sdk#readme",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "clean": "npm run clean --workspaces",
    "pack:dry-run": "npm pack --dry-run --workspace harness-app-sdk && npm pack --dry-run --workspace create-harness-app",
    "test": "vitest run",
    "test:live": "HARNESS_APP_SDK_LIVE=1 vitest run packages/harness-app-sdk/test/live.test.ts",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20"
  }
}
